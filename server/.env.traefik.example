# ── Traefik runtime config ─────────────────────────────────────────────────
# Copy this file to .env.traefik and fill in real values.
#
# If you ARE using a domain (e.g. api.example.com), fill these out.
# If you ARE NOT using a domain (IP access only), you can leave these blank.

# Your public domain for the Django API
TRAEFIK_DOMAIN=

# Email used for Let's Encrypt certificates
ACME_EMAIL=
