# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,api.autosagex.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://autosagex.web.app

# Vault Field Encryption Key
VAULT_ENCRYPTION_KEY=your-vault-encryption-key-here

# Supabase PostgreSQL Database Configuration
DATABASE_URL=postgresql://postgres:your-password@db.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.supabase.co:5432/postgres

# Clerk Configuration Keys
CLERK_PUBLISHABLE_KEY=pk_test_CLERK_KEY
CLERK_SECRET_KEY=sk_test_CLERK_KEY

# Execution Worker
# LOCAL dev:   http://localhost:8020/api/worker/execute
# IN DOCKER:   http://host.docker.internal:8020/api/worker/execute  (use --add-host=host.docker.internal:host-gateway in docker run)
EXEC_WORKER_URL="http://localhost:8020/api/worker/execute"
WORKER_API_KEY="wk_dev_s3cur3_k3y_ch4ng3_1n_pr0d"

# Environment (PROD / DEV)
# DEV  → plain X-API-Key only (no OIDC token, metadata server unavailable locally).
# PROD → attaches Authorization: Bearer <OIDC token> via GCE metadata server (ADC).
ENVIRONMENT=DEV

# Cloud Run exec-worker base URL used as the OIDC token audience in PROD.
# Must match the deployed service root URL exactly (no trailing path).
EXEC_WORKER_AUDIENCE=https://your-cloud-run-service-url.a.run.app

# Google Cloud Credentials
GOOGLE_APPLICATION_CREDENTIALS="path/to/your/service-account.json"

# GitHub PAT
GHCR_PAT=your-github-pat-here