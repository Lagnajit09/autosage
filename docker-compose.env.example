# ── docker-compose.env.example ─────────────────────────────────────────────
# Copy to:   .env.server   (for the Django/Uvicorn service)
#            .env.worker   (for the FastAPI exec-worker service)
# Fill in real values before running:  docker compose up --build
#
# NEVER commit .env.server or .env.worker to git.
# ─────────────────────────────────────────────────────────────────────────────

# ════════════════════════════════╗
# .env.server                     ║
# ════════════════════════════════╝

# Django core
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,autosagex-server
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://autosagex.web.app

# Vault field-level encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
VAULT_ENCRYPTION_KEY=change-me-to-a-fernet-key

# Supabase / PostgreSQL
DATABASE_URL=postgresql://postgres:your-password@db.xxxx.supabase.co:5432/postgres

# Clerk authentication
CLERK_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Exec-worker — DO NOT change this in a compose deployment; it is overridden
# in docker-compose.yml to use Docker-internal DNS (http://exec-worker:8020).
# Leave blank or set to the internal value; the compose file wins.
EXEC_WORKER_URL=http://exec-worker:8020/api/worker/execute

# Environment (PROD / DEV)
# DEV  → plain X-API-Key only (no OIDC token, metadata server unavailable locally).
# PROD → attaches Authorization: Bearer <OIDC token> via GCE metadata server (ADC).
ENVIRONMENT=DEV

# Cloud Run exec-worker base URL used as the OIDC token audience in PROD.
# Must match the deployed service root URL exactly (no trailing path).
EXEC_WORKER_AUDIENCE=https://your-cloud-run-service-url.a.run.app

# Must match WORKER_API_KEY in .env.worker
WORKER_API_KEY=change-me-to-a-strong-shared-secret

# Path inside the container to the GCS service-account key (bind-mounted).
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcs-key.json


# ════════════════════════════════╗
# .env.worker                     ║
# ════════════════════════════════╝

# Must match WORKER_API_KEY in .env.server
WORKER_API_KEY=change-me-to-a-strong-shared-secret

# Path inside the container to the GCS service-account key (bind-mounted).
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcs-key.json

# Environement (PROD / DEV)
ENVIRONMENT=DEV
